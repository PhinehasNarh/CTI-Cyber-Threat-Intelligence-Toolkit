# ─── CTI Platform Configuration ───────────────────────────────────
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
#
# All API keys are OPTIONAL — the app runs without them,
# but enrichment features will be limited.
# ──────────────────────────────────────────────────────────────────

# VirusTotal — IOC hash lookups + domain reputation
# Free: 4 req/min, 500/day → https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# AbuseIPDB — IP reputation and abuse reports
# Free: 1,000 checks/day → https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# Shodan — port/vuln scanning (InternetDB is free without key)
# Free: limited → https://account.shodan.io/register
SHODAN_API_KEY=

# GreyNoise — identifies scanners and internet noise
# Community: 50 queries/day → https://viz.greynoise.io/signup
GREYNOISE_API_KEY=

# AlienVault OTX — open threat exchange feeds
# Free → https://otx.alienvault.com/accounts/signup
OTX_API_KEY=

# ─── App Settings ────────────────────────────────────────────────

# How often to auto-poll feeds (in minutes)
FEED_POLL_INTERVAL=30

# Database URL (default: SQLite in current directory)
DATABASE_URL=sqlite+aiosqlite:///./cti.db
